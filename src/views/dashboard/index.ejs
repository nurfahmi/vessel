<% var pageTitle = 'Dashboard' %>

<div class="mb-6">
  <h2 class="text-2xl font-bold text-white">Fleet Overview</h2>
  <p class="text-slate-400 text-sm mt-1">VLGC fleet status and statistics</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <!-- Total Fleet -->
  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <span class="text-slate-400 text-sm">Kpler Fleet</span>
      <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      </div>
    </div>
    <div class="text-3xl font-bold text-white"><%= fleetStats.total || 0 %></div>
    <div class="text-xs text-slate-500 mt-1">total VLGC vessels</div>
  </div>

  <!-- Active -->
  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <span class="text-slate-400 text-sm">Active</span>
      <div class="w-10 h-10 rounded-lg bg-emerald-600/20 flex items-center justify-center">
        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
    </div>
    <div class="text-3xl font-bold text-white"><%= fleetStats.active || 0 %></div>
    <div class="text-xs text-slate-500 mt-1">actively trading</div>
  </div>

  <!-- Under Construction -->
  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <span class="text-slate-400 text-sm">Under Construction</span>
      <div class="w-10 h-10 rounded-lg bg-amber-600/20 flex items-center justify-center">
        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
      </div>
    </div>
    <div class="text-3xl font-bold text-white"><%= fleetStats.uc || 0 %></div>
    <div class="text-xs text-slate-500 mt-1">newbuilds</div>
  </div>

  <!-- Enriched -->
  <div class="card">
    <div class="flex items-center justify-between mb-3">
      <span class="text-slate-400 text-sm">Enriched</span>
      <div class="w-10 h-10 rounded-lg bg-purple-600/20 flex items-center justify-center">
        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
    </div>
    <div class="text-3xl font-bold text-white"><%= enrichedCount %></div>
    <div class="text-xs text-slate-500 mt-1">vessels with detail data</div>
  </div>
</div>

<!-- API Status + Fleet Stats -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
  <!-- Kpler API Status -->
  <div class="card">
    <h3 class="text-sm font-semibold text-slate-300 mb-3">Kpler API Status</h3>
    <div class="space-y-3">
      <!-- Token Status -->
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Token</span>
        <div class="flex items-center gap-2">
          <% if (tokenStatus === 'active') { %>
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-xs text-emerald-400">Active</span>
            <span class="text-[10px] text-slate-500">(<%= tokenAge %>m ago)</span>
          <% } else if (tokenStatus === 'stale') { %>
            <span class="w-2 h-2 rounded-full bg-amber-400"></span>
            <span class="text-xs text-amber-400">Stale</span>
            <span class="text-[10px] text-slate-500">(<%= tokenAge %>m ago)</span>
          <% } else if (tokenStatus === 'expired') { %>
            <span class="w-2 h-2 rounded-full bg-red-400"></span>
            <span class="text-xs text-red-400">Expired</span>
          <% } else { %>
            <span class="w-2 h-2 rounded-full bg-slate-600"></span>
            <span class="text-xs text-slate-500">No token</span>
          <% } %>
        </div>
      </div>

      <!-- Auto-Refresh -->
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Auto-Refresh</span>
        <span class="text-xs <%= hasRefreshToken ? 'text-emerald-400' : 'text-slate-500' %>">
          <%= hasRefreshToken ? '✓ Every 4 min' : '✗ Not configured' %>
        </span>
      </div>

      <!-- Last Sync -->
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Last Sync</span>
        <span class="text-xs text-slate-300">
          <% if (lastSync) { %>
            <%= new Date(lastSync).toLocaleString() %>
          <% } else { %>
            <span class="text-slate-500">Never</span>
          <% } %>
        </span>
      </div>

      <% if (tokenStatus !== 'active') { %>
        <a href="/settings" class="block text-center text-xs text-blue-400 hover:text-blue-300 mt-2">
          <%= tokenStatus === 'inactive' ? 'Configure token in Settings →' : 'Refresh token in Settings →' %>
        </a>
      <% } %>
    </div>
  </div>

  <!-- Fleet Status -->
  <div class="card">
    <h3 class="text-sm font-semibold text-slate-300 mb-3">Fleet Status</h3>
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Ballast (Open)</span>
        <span class="text-blue-300 font-medium"><%= fleetStats.ballast || 0 %></span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Loaded</span>
        <span class="text-emerald-300 font-medium"><%= fleetStats.loaded || 0 %></span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">No AIS Signal</span>
        <span class="text-red-400 font-medium"><%= fleetStats.no_ais || 0 %></span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-sm text-slate-400">Voyage Data</span>
        <span class="text-slate-300 text-xs"><%= voyageStats.destinations %> dest · <%= voyageStats.transitRoutes %> routes · <%= voyageStats.portAreas %> ports</span>
      </div>
      <!-- Bar -->
      <div class="mt-2">
        <div class="flex h-2 rounded-full overflow-hidden bg-slate-700">
          <% const total = parseInt(fleetStats.active) || 1; %>
          <div class="bg-blue-500" style="width: <%= Math.round((fleetStats.ballast || 0) / total * 100) %>%"></div>
          <div class="bg-emerald-500" style="width: <%= Math.round((fleetStats.loaded || 0) / total * 100) %>%"></div>
          <div class="bg-red-500/50" style="width: <%= Math.round((fleetStats.no_ais || 0) / total * 100) %>%"></div>
        </div>
        <div class="flex justify-between text-[10px] text-slate-500 mt-1">
          <span>Ballast <%= Math.round((fleetStats.ballast || 0) / total * 100) %>%</span>
          <span>Loaded <%= Math.round((fleetStats.loaded || 0) / total * 100) %>%</span>
          <span class="text-red-400/70">No AIS <%= Math.round((fleetStats.no_ais || 0) / total * 100) %>%</span>
        </div>
      </div>
    </div>
  </div>
</div>
