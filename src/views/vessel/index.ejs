<% var pageTitle = 'Control List' %>

<div class="flex items-center justify-between mb-4">
  <div>
    <h2 class="text-2xl font-bold text-white">Control List</h2>
    <p class="text-slate-400 text-sm mt-1">Master vessel registry — <%= vessels.length %> vessels</p>
  </div>
  <form method="GET" class="flex items-center gap-2">
    <input type="text" name="q" value="<%= q %>" placeholder="Search vessels..." class="input input-sm w-64">
    <button type="submit" class="btn btn-sm btn-primary">Search</button>
    <% if (q) { %><a href="/vessels" class="btn btn-sm bg-slate-700 text-white">Clear</a><% } %>
  </form>
</div>

<!-- Add Vessel -->
<details class="card mb-4">
  <summary class="cursor-pointer text-sm font-medium text-slate-300 hover:text-white">+ Add New Vessel</summary>
  <form action="/vessels" method="POST" class="mt-4 grid grid-cols-6 gap-3">
    <div class="col-span-2"><input type="text" name="name" required placeholder="Vessel Name" class="input input-sm w-full"></div>
    <div><input type="text" name="built" placeholder="Built" class="input input-sm w-full"></div>
    <div><input type="number" name="cbm" placeholder="CBM" class="input input-sm w-full"></div>
    <div><input type="text" name="controller" placeholder="Controller" class="input input-sm w-full"></div>
    <div>
      <select name="scrubber_df" class="input input-sm w-full">
        <option value="none">None</option>
        <option value="scrubber">Scrubber</option>
        <option value="dual_fuel">Dual Fuel</option>
        <option value="deck_tank">Deck Tank</option>
      </select>
    </div>
    <div class="col-span-6 flex items-center gap-4">
      <label class="flex items-center gap-1 text-xs text-slate-300"><input type="checkbox" name="us_trade" value="1"> US Trade</label>
      <label class="flex items-center gap-1 text-xs text-slate-300"><input type="checkbox" name="chinese_built" value="1"> Chinese</label>
      <label class="flex items-center gap-1 text-xs text-slate-300"><input type="checkbox" name="panamax" value="1"> Panamax</label>
      <label class="flex items-center gap-1 text-xs text-slate-300"><input type="checkbox" name="deck_tank" value="1"> Deck Tank</label>
      <input type="text" name="head_owner" placeholder="Head Owner" class="input input-sm">
      <input type="text" name="imo" placeholder="IMO" class="input input-sm w-28">
      <input type="text" name="mmsi" placeholder="MMSI" class="input input-sm w-28">
      <button type="submit" class="btn btn-sm btn-success ml-auto">Add Vessel</button>
    </div>
  </form>
</details>

<div class="card p-0 overflow-hidden">
  <div class="overflow-x-auto max-h-[calc(100vh-280px)]">
    <table class="data-table">
      <thead>
        <tr>
          <th>Tracked</th><th>#</th><th>Vessel Name</th><th>Built</th><th>CBM</th><th>US</th><th>CN</th><th>PMX</th><th>DT</th><th>S/DF</th><th>Controller</th><th>Head Owner</th><th>IMO</th><th class="w-12"></th>
        </tr>
      </thead>
      <tbody>
        <% vessels.forEach((v, i) => { %>
          <tr>
            <td class="text-center">
              <input type="checkbox" <%= v.tracked ? 'checked' : '' %>
                onchange="fetch('/vessels/api/toggle-tracked/<%= v.id %>',{method:'POST'}).then(r=>r.json()).then(d=>{this.checked=d.tracked})" 
                class="w-4 h-4 accent-emerald-500 cursor-pointer" title="Track this vessel">
            </td>
            <td class="text-slate-500"><%= i + 1 %></td>
            <td class="font-medium text-white"><%= v.name %></td>
            <td><%= v.built || '' %></td>
            <td><%= v.cbm ? Math.round(v.cbm).toLocaleString() : '' %></td>
            <td class="text-center"><%= v.us_trade ? 'US' : '' %></td>
            <td class="text-center"><%= v.chinese_built ? 'C' : '' %></td>
            <td class="text-center"><%= v.panamax ? 'P' : '' %></td>
            <td class="text-center"><%= v.deck_tank ? 'DT' : '' %></td>
            <td class="text-[10px]"><%= v.scrubber_df === 'none' ? '' : v.scrubber_df === 'scrubber' ? 'S' : v.scrubber_df === 'dual_fuel' ? 'DF' : 'DT' %></td>
            <td class="text-blue-300"><%= v.controller || '' %></td>
            <td class="text-slate-400"><%= v.head_owner || '' %></td>
            <td class="text-slate-500 text-[10px]"><%= v.imo || '' %></td>
            <td>
              <button onclick="if(confirm('Delete?')) fetch('/vessels/<%= v.id %>',{method:'DELETE'}).then(()=>location.reload())" class="text-red-400 hover:text-red-300 text-xs">✕</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
