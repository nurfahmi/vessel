<% var pageTitle = 'Fleet Availability' %>

<style>
  @media print {
    body, html { background: white !important; }
    .sidebar, .topbar, .no-print, nav { display: none !important; }
    .main-content { margin: 0 !important; padding: 0 !important; }
    .card { border: 1px solid #ddd !important; background: white !important; box-shadow: none !important; }
    table { font-size: 8px !important; }
    th, td { color: #111 !important; border-bottom: 1px solid #ddd !important; padding: 2px 3px !important; }
    th { background: #f3f4f6 !important; font-weight: 700 !important; }
    .sticky { position: static !important; }
    .print-header { display: block !important; }
    a { color: #111 !important; text-decoration: none !important; }
    .badge-tag { border: 1px solid #999 !important; background: #eee !important; color: #111 !important; }
  }
  .print-header { display: none; }
  .sort-btn { cursor: pointer; user-select: none; }
  .sort-btn:hover { color: #67e8f9; }
  .sort-btn::after { content: ' ↕'; font-size: 8px; opacity: 0.4; }
  .sort-btn.asc::after { content: ' ↑'; opacity: 1; }
  .sort-btn.desc::after { content: ' ↓'; opacity: 1; }
  .badge-tag { font-size: 8px; padding: 1px 4px; border-radius: 3px; display: inline-block; line-height: 1.3; }
  .bg-open { background: rgba(16,185,129,0.15); color: #6ee7b7; }
  .bg-us { background: rgba(239,68,68,0.12); color: #fca5a5; }
  .bg-cn { background: rgba(251,191,36,0.12); color: #fcd34d; }
  .bg-pm { background: rgba(99,102,241,0.12); color: #a5b4fc; }
  .bg-fs { background: rgba(244,114,182,0.12); color: #f9a8d4; }
  .pos-select {
    background: transparent; border: 0; color: #e2e8f0; font-size: 10px; font-weight: 500;
    outline: none; cursor: pointer; padding: 2px 0; width: 100%; min-width: 90px;
  }
  .pos-select option { background: #1e293b; }
  .pos-select.manual { color: #fbbf24; }
  .pos-select.auto { color: #94a3b8; }
  .avail-select {
    background: transparent; border: 0; color: #e2e8f0; font-size: 10px; font-weight: 500;
    outline: none; cursor: pointer; padding: 2px 0; width: 100%;
  }
  .avail-select option { background: #1e293b; }
  .inline-input {
    background: transparent; border: none; color: #94a3b8; font-size: 10px; width: 100%;
    padding: 2px 4px; border-radius: 3px; outline: none;
  }
  .inline-input:focus { background: #334155; color: #e2e8f0; }
  @media (max-width: 768px) {
    .data-table .sticky { position:static !important; left:auto !important; }
  }
  /* Resizable columns */
  #availTable th { position: relative; overflow: hidden; }
  #availTable th .resize-handle {
    position: absolute; right: 0; top: 0; bottom: 0; width: 4px;
    cursor: col-resize; background: transparent; z-index: 5;
  }
  #availTable th .resize-handle:hover, #availTable th .resize-handle.active { background: #67e8f9; }
  .inline-operator {
    background: transparent; border: none; color: #93c5fd; font-size: 10px; width: 100%;
    padding: 2px 4px; border-radius: 3px; outline: none; cursor: text;
  }
  .inline-operator:focus { background: #334155; color: #e2e8f0; }
  .inline-operator.manual { color: #fbbf24; }
  .notes-inline {
    background: transparent; border: none; color: #94a3b8; font-size: 10px; width: 100%;
    padding: 2px 4px; border-radius: 3px; outline: none; resize: none; min-height: 20px;
  }
  .notes-inline:focus { background: #334155; color: #e2e8f0; min-height: 50px; }
  #colMenu.active { display:block !important; }
  #colMenu label { display:flex;align-items:center;gap:4px;font-size:10px;color:#94a3b8;padding:2px 4px;border-radius:3px;cursor:pointer;white-space:nowrap; }
  #colMenu label:hover { background:rgba(255,255,255,0.05);color:#e2e8f0; }
  #colMenu input { width:12px;height:12px;accent-color:#3b82f6; }

</style>

<div class="print-header" style="padding: 20px 0 10px;">
  <h1 style="font-size: 18px; font-weight: 700; color: #111;">VLGC Fleet Availability — Open Tonnage</h1>
  <p style="font-size: 11px; color: #666; margin-top: 4px;">
    Generated: <%= new Date().toLocaleDateString('en-GB', {day:'2-digit', month:'short', year:'numeric'}) %> · <%= vessels.length %> vessels
  </p>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 no-print gap-2">
  <div>
    <h2 class="text-lg font-bold" style="color:var(--text-primary);">Fleet Availability</h2>
    <p class="text-[11px] mt-0.5" style="color:var(--text-muted);">
      <%= vessels.length %> vessels<%= showAll ? '' : ' (★ tracked)' %> · ETAs from open position
      <% if (!showAll) { %>
        · <a href="?all=1" style="color:#67e8f9;">show all</a>
      <% } else { %>
        · <a href="/availability" style="color:#fbbf24;">★ tracked only</a>
      <% } %>
    </p>
  </div>
  <div class="flex items-center gap-2">
    <div class="flex items-center gap-1" style="background:var(--bg-input);border-radius:6px;padding:2px 4px;">
      <button onclick="refreshFleet(this)" class="btn btn-sm" style="background:#0f766e;color:white;padding:3px 8px;border-radius:4px;font-size:10px;cursor:pointer;display:inline-flex;align-items:center;gap:3px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg> Refresh</button>
      <select id="enrichHours" style="background:transparent;color:#a78bfa;border:0;font-size:10px;outline:none;cursor:pointer;">
        <option value="1">1h</option><option value="4">4h</option><option value="8">8h</option>
        <option value="12" selected>12h</option><option value="24">24h</option><option value="0">Force</option>
      </select>
    </div>
    <a href="/kpler-vessels" class="btn btn-sm" style="background:#334155;color:#94a3b8;padding:3px 10px;border-radius:4px;font-size:10px;text-decoration:none;display:inline-flex;align-items:center;gap:3px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20l2-2h16l2 2"/><path d="M4 18V8a2 2 0 012-2h12a2 2 0 012 2v10"/><path d="M12 6V2"/></svg> Fleet</a>
    <% if (!fullScreen) { %>
      <a href="?full=1" class="btn btn-sm" style="background:#475569;color:white;padding:3px 10px;border-radius:4px;font-size:10px;text-decoration:none;display:inline-flex;align-items:center;gap:3px;" target="_blank"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg> Full Table</a>
    <% } else { %>
      <a href="/availability" class="btn btn-sm" style="background:#475569;color:white;padding:3px 10px;border-radius:4px;font-size:10px;text-decoration:none;display:inline-flex;align-items:center;gap:3px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Exit Full</a>
      <div class="flex items-center gap-0" style="background:var(--bg-input);border-radius:6px;padding:1px 2px;">
        <button onclick="zoomTable(-10)" style="background:none;border:none;color:#94a3b8;font-size:12px;cursor:pointer;padding:2px 6px;">−</button>
        <span id="zoomLevel" style="font-size:9px;color:#67e8f9;min-width:30px;text-align:center;">100%</span>
        <button onclick="zoomTable(10)" style="background:none;border:none;color:#94a3b8;font-size:12px;cursor:pointer;padding:2px 6px;">+</button>
        <button onclick="zoomTable(0)" style="background:none;border:none;color:#64748b;font-size:9px;cursor:pointer;padding:2px 4px;">Reset</button>
      </div>
    <% } %>
    <div style="position:relative;display:inline-block;">
      <button onclick="var m=document.getElementById('colMenu');m.style.display=m.style.display==='block'?'none':'block'" class="btn btn-sm" style="background:#334155;color:#94a3b8;padding:3px 10px;border-radius:4px;font-size:10px;cursor:pointer;display:inline-flex;align-items:center;gap:3px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg> Columns</button>
      <div id="colMenu" style="display:none;position:absolute;right:0;top:100%;margin-top:4px;background:#1e293b;border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:6px;z-index:999;min-width:140px;max-height:300px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,0.5);">
      </div>
    </div>
    <a href="/availability/export" class="btn btn-sm" style="background:#0f766e;color:white;padding:3px 10px;border-radius:4px;font-size:10px;text-decoration:none;display:inline-flex;align-items:center;gap:3px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg> Excel</a>
  </div>
</div>
<div class="filter-bar mb-3 no-print">
  <input type="text" id="searchInput" placeholder="Search..." oninput="filterTable()" style="width:120px;">
  <div class="filter-sep"></div>
  <select id="filterController" onchange="filterTable()">
    <option value="">All Operators</option>
    <% controllers.forEach(c => { %>
      <option value="<%= c %>" <%= filter === c ? 'selected' : '' %>><%= c %></option>
    <% }) %>
  </select>
  <select id="filterState" onchange="filterTable()">
    <option value="">All States</option>
    <option value="ballast">Ballast</option>
    <option value="loaded">Loaded</option>
  </select>
  <select id="filterAvail" onchange="filterTable()">
    <option value="">All Status</option>
    <option value="open">Open</option>
    <option value="relet">Relet</option>
    <option value="tc">TC</option>
  </select>
  <select id="filterPosition" onchange="filterTable()">
    <option value="">All Positions</option>
    <% positionOptions.forEach(p => { %>
      <option value="<%= p %>"><%= p %></option>
    <% }) %>
  </select>
  <div class="filter-sep"></div>
  <span class="filter-label">Open:</span>
  <input type="date" id="filterDateFrom" onchange="filterTable()" style="width:110px;">
  <span class="filter-label">→</span>
  <input type="date" id="filterDateTo" onchange="filterTable()" style="width:110px;">
</div>
<div id="enrichStatus" style="display:none;" class="text-[10px] text-purple-300 mb-2"></div>

<div class="card p-0 overflow-hidden">
  <div class="overflow-x-auto max-h-[calc(100vh-200px)]">
    <table class="data-table text-[11px]" id="availTable">
      <thead>
        <tr>
          <th class="sticky left-0 z-20 bg-slate-900 w-8">#</th>
          <th class="sticky left-8 z-20 bg-slate-900 min-w-[140px] sort-btn" data-col="name" onclick="sortTable('name')">Vessel</th>
          <th class="sort-btn" data-col="ctrl" onclick="sortTable('ctrl')">Controller</th>
          <th class="sort-btn text-center" data-col="cbm" onclick="sortTable('cbm')">CBM</th>
          <th class="sort-btn text-center" data-col="blt" onclick="sortTable('blt')">BLT</th>
          <th class="sort-btn" data-col="state" onclick="sortTable('state')">State</th>
          <th class="sort-btn" data-col="pos" onclick="sortTable('pos')">Position</th>
          <th>Last Port</th>
          <th>Next Dest</th>
          <th class="sort-btn" data-col="avail" onclick="sortTable('avail')">Status</th>
          <th class="sort-btn" data-col="seen" onclick="sortTable('seen')">Last Seen</th>
          <th class="border-l border-emerald-800 text-emerald-300 sort-btn" data-col="from" onclick="sortTable('from')">Open From</th>
          <th class="text-emerald-300 sort-btn" data-col="to" onclick="sortTable('to')">Open To</th>
          <th class="border-l border-slate-700">Notes</th>
          <th>Voyage</th>
          <th class="text-orange-300 text-center text-[9px] border-l border-slate-700">DD</th>
          <% destinations.forEach(d => { %>
            <th class="border-l border-slate-700 text-center text-cyan-300 sort-btn" data-col="eta_<%= d.key %>" onclick="sortTable('eta_<%= d.key %>')"><%= d.short_label %></th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% function fmtDate(d) { if (!d) return ''; const dt = new Date(d); return dt.getFullYear() + '-' + String(dt.getMonth()+1).padStart(2,'0') + '-' + String(dt.getDate()).padStart(2,'0'); } %>
        <% vessels.forEach((v, i) => { %>
        <tr data-controller="<%= v.controller || '' %>" data-state="<%= v.state || '' %>" data-name="<%= v.name %>"
            data-position="<%= v.position || '' %>"
            data-avail="<%= v.avail_status || v.vessel_availability || '' %>"
            data-kpler="<%= v.kpler_id %>"
            data-sort-name="<%= v.name %>"
            data-sort-cbm="<%= v.cbm || 0 %>"
            data-sort-blt="<%= v.built_year || 0 %>"
            data-sort-ctrl="<%= v.controller || '' %>"
            data-sort-state="<%= v.state || '' %>"
            data-sort-pos="<%= v.position || '' %>"
            data-sort-avail="<%= v.avail_status || v.vessel_availability || '' %>"
            data-sort-seen="<%= v.position_time ? new Date(v.position_time).getTime() : 0 %>"
            data-sort-from="<%= v.open_from ? new Date(v.open_from).getTime() : 0 %>"
            data-sort-to="<%= v.open_to ? new Date(v.open_to).getTime() : 0 %>"
            <% destinations.forEach(d => { %>
              data-sort-eta_<%= d.key %>="<%= v.etas[d.key] ? v.etas[d.key].eta1.getTime() : 99999999999999 %>"
            <% }) %>
        >
          <td class="sticky left-0 bg-slate-900 text-slate-500 text-[10px]"><%= i + 1 %></td>
          <td class="sticky left-8 bg-slate-900">
            <a href="/kpler-vessels/<%= v.kpler_id %>" class="text-white font-medium hover:text-cyan-300 transition-colors text-[11px]"><%= v.name %></a>
            <div class="flex gap-0.5 mt-0.5">
              <% if (v.beam && parseFloat(v.beam) <= 32.31) { %><span class="badge-tag bg-pm" title="Panamax (beam: <%= v.beam %>m)">PMAX</span><% } %>
              <% if (v.is_ethylene_capable) { %><span class="badge-tag" style="background:rgba(16,185,129,0.12);color:#6ee7b7" title="Ethylene">ETH</span><% } %>
              <% if (v.is_floating_storage) { %><span class="badge-tag bg-fs" title="Floating Storage">FS</span><% } %>
            </div>
          </td>
          <td>
            <input class="inline-operator <%= v._isManualOperator ? 'manual' : '' %>" 
                   value="<%= v._operator || '' %>" 
                   title="<%= v._isManualOperator ? 'Manual override' : 'From API' %> — click to edit"
                   onchange="saveAvailField(<%= v.kpler_id %>, 'manual_operator', this.value)"
                   style="min-width:80px;">
          </td>
          <td class="text-slate-300 text-[10px] text-center whitespace-nowrap"><%= v.cbm ? v.cbm.toLocaleString() : '' %></td>
          <td class="text-slate-400 text-[10px] text-center"><%= v.built_year || '' %></td>
          <td>
            <% if (v.state) { %>
              <span class="px-1 rounded text-[8px] font-medium
                <%= v.state === 'loaded' ? 'bg-emerald-900/50 text-emerald-300' : 
                   v.state === 'ballast' ? 'bg-blue-900/50 text-blue-300' : 
                   'bg-slate-700 text-slate-300' %>"><%= v.state.toUpperCase() %></span>
            <% } %>
            <% if (v.cargo_products) { %><div class="text-[8px] text-amber-300 truncate max-w-[60px]" title="<%= v.cargo_products %>"><%= v.cargo_products %></div><% } %>
          </td>
          <td>
            <select class="pos-select <%= v._isManualPos ? 'manual' : 'auto' %>" onchange="savePosition(<%= v.kpler_id %>, this)">
              <option value="">—</option>
              <% positionOptions.forEach(p => { %>
                <option value="<%= p %>" <%= v.position === p ? 'selected' : '' %>><%= p %></option>
              <% }) %>
            </select>
          </td>
          <td class="text-[10px] text-slate-400 whitespace-nowrap" title="<%= [v.last_port, v.last_port_country].filter(Boolean).join(', ') %>">
            <%= v.last_port || '' %>
          </td>
          <td class="text-[10px] text-amber-300 whitespace-nowrap">
            <% 
              const destZone = (v.next_dest_zone || '').trim();
              const destAis = (v.ais_destination || '').trim();
              const destEta = v.next_dest_eta || v.ais_eta;
              const destMapped = v._destDisplay;
            %>
            <% if (destMapped) { %>
              <span title="AIS: <%= destAis %>"><%= destMapped %></span>
              <span class="text-[8px] text-slate-500 ml-0.5">(<%= destAis %>)</span>
            <% } else if (destZone) { %>
              <%= destZone %>
              <% if (destAis && destAis !== destZone) { %>
                <span class="text-[8px] text-slate-500 ml-0.5"><%= destAis %></span>
              <% } %>
            <% } else if (destAis) { %>
              <%= destAis %>
              <span class="text-[8px] text-slate-500 ml-0.5">AIS</span>
            <% } else { %>
              <span class="text-slate-600">—</span>
            <% } %>
            <% if (destEta) { %>
              <div class="text-[9px] text-slate-400"><%= new Date(destEta).toLocaleDateString('en-GB', {day:'2-digit', month:'short', year:'2-digit'}) %></div>
            <% } %>
          </td>
          <td>
            <select class="avail-select" onchange="saveAvailField(<%= v.kpler_id %>, 'avail_status', this.value)" 
                    style="color:<%= (v.avail_status||'') === 'Open' ? '#6ee7b7' : (v.avail_status||'') === 'Relet' ? '#fcd34d' : (v.avail_status||'') === 'TC' ? '#a5b4fc' : '#64748b' %>">
              <option value="" <%= !v.avail_status ? 'selected' : '' %>>—</option>
              <option value="Open" <%= v.avail_status === 'Open' ? 'selected' : '' %>>Open</option>
              <option value="Relet" <%= v.avail_status === 'Relet' ? 'selected' : '' %>>Relet</option>
              <option value="TC" <%= v.avail_status === 'TC' ? 'selected' : '' %>>TC</option>
            </select>
          </td>
          <td class="text-[10px] whitespace-nowrap">
            <% if (v.position_time) {
              const now = new Date();
              const seen = new Date(v.position_time);
              const diffH = Math.round((now - seen) / 3600000);
              const diffD = Math.round(diffH / 24);
              const label = diffH < 24 ? diffH + 'h' : diffD + 'd';
              const color = diffD > 7 ? 'text-red-400' : diffD > 3 ? 'text-amber-400' : diffD > 1 ? 'text-yellow-300' : 'text-slate-300';
            %>
              <span class="<%= color %>" title="<%= seen.toISOString().replace('T',' ').substring(0,16) %>"><%= label %> ago</span>
            <% } %>
          </td>
          <td class="border-l border-emerald-800/30 whitespace-nowrap">
            <input type="date" class="inline-input text-emerald-300 font-medium" 
                   value="<%= fmtDate(v.open_from) %>"
                   onchange="saveDateField(<%= v.kpler_id %>, 'manual_open_from', this.value, this)"
                   style="width:85px;" <%= v.manual_open_from ? 'title="Manual"' : 'title="Auto-calculated"' %>>
          </td>
          <td class="whitespace-nowrap">
            <input type="date" class="inline-input text-emerald-300/70" 
                   value="<%= fmtDate(v.open_to) %>"
                   onchange="saveDateField(<%= v.kpler_id %>, 'manual_open_to', this.value, this)"
                   style="width:85px;">
          </td>
          <td class="border-l border-slate-800" style="min-width:120px;">
            <textarea class="notes-inline" rows="1"
                      onchange="saveAvailField(<%= v.kpler_id %>, 'avail_notes', this.value)"
                      placeholder="—"><%= v._notes || '' %></textarea>
          </td>
          <td>
            <input class="inline-input text-cyan-300" value="<%= v.avail_voyage || '' %>" placeholder="—"
                   onchange="saveAvailField(<%= v.kpler_id %>, 'avail_voyage', this.value)"
                   style="min-width:80px;">
          </td>
          <td class="text-center border-l border-slate-700">
            <% if (v._dischargeDays) { %>
              <input type="number" class="bg-transparent text-orange-300 text-[10px] font-mono text-center w-10 border-0 outline-none"
                     value="<%= v._dischargeDays %>" min="1" max="30"
                     title="<%= v._open_position || '' %>: discharge days"
                     data-area="<%= v._open_position || '' %>"
                     onchange="saveDischarge(this)">
            <% } else { %>
              <span class="text-[9px] text-slate-600">—</span>
            <% } %>
          </td>
          <% destinations.forEach(d => { %>
            <td class="border-l border-slate-800 text-center whitespace-nowrap" data-eta-key="<%= d.key %>">
              <% if (v.etas[d.key]) { 
                const e = v.etas[d.key];
                const d1 = e.eta1.getDate().toString().padStart(2,'0');
                const d2 = e.eta2.getDate().toString().padStart(2,'0');
                const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                const mon = months[e.eta2.getMonth()];
                const display = d1 === d2 ? d1 + ' ' + mon : d1 + '-' + d2 + ' ' + mon;
              %>
                <span class="text-slate-200" title="<%= Math.round(e.days) %> transit days"><%= display %></span>
              <% } else { %>
                <span class="text-slate-700">—</span>
              <% } %>
            </td>
          <% }) %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
// Transit lookup for client-side ETA recalculation
const transitLookup = <%- transitLookup %>;
const destKeys = [<% destinations.forEach((d, i) => { %>'<%= d.key %>'<%= i < destinations.length-1 ? ',' : '' %><% }) %>];

let currentSort = { col: null, dir: null };
let zoomPct = 100;

function zoomTable(delta) {
  if (delta === 0) { zoomPct = 100; } else { zoomPct = Math.max(50, Math.min(150, zoomPct + delta)); }
  const table = document.getElementById('availTable');
  table.style.fontSize = (zoomPct / 100 * 11) + 'px';
  document.getElementById('zoomLevel').textContent = zoomPct + '%';
}

function sortTable(col) {
  const tbody = document.querySelector('#availTable tbody');
  const rows = Array.from(tbody.querySelectorAll('tr'));
  
  if (currentSort.col === col) {
    currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
  } else {
    currentSort.col = col;
    currentSort.dir = 'asc';
  }
  
  document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.classList.remove('asc', 'desc');
    if (btn.dataset.col === col) btn.classList.add(currentSort.dir);
  });
  
  const isNumeric = ['cbm', 'blt', 'from', 'to', 'seen'].includes(col) || col.startsWith('eta_');
  
  rows.sort((a, b) => {
    let va = a.getAttribute('data-sort-' + col) || '';
    let vb = b.getAttribute('data-sort-' + col) || '';
    if (isNumeric) { va = parseFloat(va) || 0; vb = parseFloat(vb) || 0; }
    else { va = va.toLowerCase(); vb = vb.toLowerCase(); }
    let result = va < vb ? -1 : va > vb ? 1 : 0;
    return currentSort.dir === 'desc' ? -result : result;
  });
  
  rows.forEach(row => tbody.appendChild(row));
  renumber();
}

function filterTable() {
  const ctrl = document.getElementById('filterController').value.toLowerCase();
  const state = document.getElementById('filterState').value.toLowerCase();
  const avail = document.getElementById('filterAvail').value.toLowerCase();
  const pos = document.getElementById('filterPosition').value;
  const search = document.getElementById('searchInput').value.toLowerCase();
  const dateFrom = document.getElementById('filterDateFrom').value;
  const dateTo = document.getElementById('filterDateTo').value;
  const dfTs = dateFrom ? new Date(dateFrom).getTime() : 0;
  const dtTs = dateTo ? new Date(dateTo + 'T23:59:59').getTime() : Infinity;
  
  document.querySelectorAll('#availTable tbody tr').forEach(row => {
    const rc = (row.dataset.controller || '').toLowerCase();
    const rs = (row.dataset.state || '').toLowerCase();
    const ra = (row.dataset.avail || '').toLowerCase();
    const rp = row.dataset.position || '';
    const rn = (row.dataset.name || '').toLowerCase();
    const rf = parseFloat(row.getAttribute('data-sort-from')) || 0;
    
    const dateMatch = (!dateFrom && !dateTo) || (rf > 0 && rf >= dfTs && rf <= dtTs);
    
    const show = (!ctrl || rc.includes(ctrl)) &&
                 (!state || rs === state) &&
                 (!avail || ra.includes(avail)) &&
                 (!pos || rp === pos) &&
                 (!search || rn.includes(search)) &&
                 dateMatch;
    row.style.display = show ? '' : 'none';
  });
  renumber();
}

function renumber() {
  let n = 0;
  document.querySelectorAll('#availTable tbody tr').forEach(row => {
    if (row.style.display !== 'none') {
      n++;
      row.children[0].textContent = n;
    }
  });
}

/** Recalculate ETAs client-side for a row (no page reload needed) */
function recalcETAs(row) {
  const posSelect = row.querySelector('.pos-select');
  const pos = posSelect ? posSelect.value : '';
  const fromInput = row.querySelector('input[type="date"]');
  const toInput = row.querySelectorAll('input[type="date"]')[1];
  const openFrom = fromInput ? fromInput.value : '';
  const openTo = toInput ? toInput.value : '';
  
  if (!pos || !openFrom) return;
  
  const from = new Date(openFrom);
  const to = openTo ? new Date(openTo) : from;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  
  destKeys.forEach((key) => {
    const cell = row.querySelector(`td[data-eta-key="${key}"]`);
    if (!cell) return;
    const days = transitLookup[`${pos}|${key}`];
    if (days !== undefined && days !== null) {
      const eta1 = new Date(from); eta1.setDate(eta1.getDate() + Math.ceil(days));
      const eta2 = new Date(to); eta2.setDate(eta2.getDate() + Math.ceil(days));
      const d1 = eta1.getDate().toString().padStart(2, '0');
      const d2 = eta2.getDate().toString().padStart(2, '0');
      const mon = months[eta2.getMonth()];
      const display = d1 === d2 ? d1 + ' ' + mon : d1 + '-' + d2 + ' ' + mon;
      cell.innerHTML = `<span class="text-slate-200" title="${Math.round(days)} transit days">${display}</span>`;
      row.setAttribute('data-sort-eta_' + key, eta1.getTime());
    } else {
      cell.innerHTML = '<span class="text-slate-700">—</span>';
      row.setAttribute('data-sort-eta_' + key, '99999999999999');
    }
  });
  
  // Update sort data
  row.setAttribute('data-sort-from', from.getTime());
  if (openTo) row.setAttribute('data-sort-to', new Date(openTo).getTime());
}

function flashSaved(el) {
  el.style.backgroundColor = '#065f4620';
  setTimeout(() => el.style.backgroundColor = '', 1000);
}

async function saveDischarge(input) {
  const area = input.dataset.area;
  if (!area) return;
  try {
    const res = await fetch('/availability/api/save-discharge', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ area, days: input.value })
    });
    if (res.ok) {
      flashSaved(input);
      // Recalc ETAs for all rows with this position
      document.querySelectorAll('#availTable tbody tr').forEach(row => recalcETAs(row));
    }
  } catch(e) { console.error(e); }
}

function savePosition(kplerId, select) {
  fetch('/kpler-vessels/api/save-position-by-kpler/' + kplerId, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ position: select.value })
  }).then(r => r.json()).then(d => {
    const row = select.closest('tr');
    row.dataset.position = select.value;
    row.setAttribute('data-sort-pos', select.value);
    recalcETAs(row);
    flashSaved(select);
  });
}

function saveAvailField(kplerId, field, value) {
  fetch('/availability/api/save-avail-field', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ kpler_id: kplerId, field, value })
  }).then(r => r.json()).then(d => {
    if (field === 'avail_status') {
      const row = document.querySelector(`tr[data-kpler="${kplerId}"]`);
      if (row) {
        row.dataset.avail = value;
        const sel = row.querySelector('.avail-select');
        if (sel) {
          sel.style.color = value === 'Open' ? '#6ee7b7' : value === 'Relet' ? '#fcd34d' : value === 'TC' ? '#a5b4fc' : '#64748b';
        }
      }
    }
  });
}

async function refreshFleet(btn) {
  const hours = document.getElementById('enrichHours').value;
  const status = document.getElementById('enrichStatus');
  btn.disabled = true;
  btn.textContent = '⏳ Syncing...';
  status.style.display = 'block';
  status.textContent = 'Syncing fleet data...';

  // Step 1: Sync
  try {
    const r = await fetch('/kpler-vessels/api/sync-fleet', { method: 'POST' });
    const d = await r.json();
    status.textContent = d.error ? '⚠ Sync: ' + d.error : `✓ Synced ${d.synced}/${d.total} vessels. Enriching...`;
  } catch(e) { status.textContent = '⚠ Sync failed, enriching anyway...'; }

  // Step 2: Enrich
  btn.textContent = '⏳ Enriching...';
  const es = new EventSource('/kpler-vessels/api/enrich-all?hours=' + hours + '&tracked=1');
  es.onmessage = (e) => {
    const d = JSON.parse(e.data);
    if (d.type === 'progress') {
      status.textContent = `${d.skip ? '⏭' : '✓'} ${d.name} — ${d.enriched} enriched, ${d.skipped} skipped, ${d.failed} failed / ${d.total}`;
    } else if (d.type === 'done') {
      status.textContent = `✅ Done: ${d.enriched} enriched, ${d.skipped} skipped, ${d.failed} failed`;
      btn.disabled = false;
      btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg> Refresh';
      es.close();
      setTimeout(() => location.reload(), 2000);
    } else if (d.type === 'error') {
      status.textContent = '❌ Error: ' + d.message;
      btn.disabled = false;
      btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg> Refresh';
      es.close();
    }
  };
  es.onerror = () => { es.close(); btn.disabled = false; btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg> Refresh'; };
}

function saveDateField(kplerId, field, value, input) {
  const row = input.closest('tr');
  
  // Auto-update Open To = Open From + 1 day
  if (field === 'manual_open_from' && value) {
    const fromDate = new Date(value);
    const toDate = new Date(fromDate.getTime() + 86400000);
    const toValue = toDate.toISOString().split('T')[0];
    const toInput = row.querySelectorAll('input[type="date"]')[1];
    if (toInput) {
      toInput.value = toValue;
      // Save Open To as well
      fetch('/availability/api/save-avail-field', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ kpler_id: kplerId, field: 'manual_open_to', value: toValue })
      });
    }
  }

  fetch('/availability/api/save-avail-field', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ kpler_id: kplerId, field, value: value || null })
  }).then(r => r.json()).then(() => {
    recalcETAs(row);
    flashSaved(input);
  });
}

// === Resizable columns ===
document.addEventListener('DOMContentLoaded', () => {
  const ths = document.querySelectorAll('#availTable thead th');
  ths.forEach(th => {
    const handle = document.createElement('div');
    handle.className = 'resize-handle';
    th.appendChild(handle);
    
    let startX, startW;
    handle.addEventListener('mousedown', e => {
      e.preventDefault();
      startX = e.pageX;
      startW = th.offsetWidth;
      handle.classList.add('active');
      
      const onMove = e2 => {
        th.style.width = Math.max(40, startW + e2.pageX - startX) + 'px';
        th.style.minWidth = th.style.width;
      };
      const onUp = () => {
        handle.classList.remove('active');
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  });
});

// Column visibility toggle
(function() {
  const menu = document.getElementById('colMenu');
  if (!menu) return;
  const ths = document.querySelectorAll('#availTable thead th');
  ths.forEach((th, i) => {
    if (i === 0) return; // skip # column
    const name = th.textContent.trim() || 'Col ' + i;
    const lbl = document.createElement('label');
    const cb = document.createElement('input');
    cb.type = 'checkbox'; cb.checked = true;
    cb.onchange = () => toggleCol(i, cb.checked);
    lbl.appendChild(cb);
    lbl.appendChild(document.createTextNode(name));
    menu.appendChild(lbl);
  });
  // Close menu on outside click
  document.addEventListener('click', e => {
    const menu = document.getElementById('colMenu');
    if (!e.target.closest('#colMenu') && !e.target.closest('[onclick*="colMenu"]')) {
      menu.style.display = 'none';
    }
  });
})();

function toggleCol(idx, show) {
  const display = show ? '' : 'none';
  document.querySelectorAll('#availTable tr').forEach(row => {
    if (row.children[idx]) row.children[idx].style.display = display;
  });
}
</script>
