<% var pageTitle = 'Drydock Schedule' %>
<div class="flex items-center justify-between mb-4">
  <h2 class="text-2xl font-bold text-white">Drydock Schedule — <%= year %></h2>
  <div class="flex gap-2">
    <a href="/drydock?year=<%= year-1 %>" class="btn btn-sm bg-slate-700 text-white">← <%= year-1 %></a>
    <a href="/drydock?year=<%= year+1 %>" class="btn btn-sm bg-slate-700 text-white"><%= year+1 %> →</a>
  </div>
</div>
<div class="card mb-4">
  <form action="/drydock" method="POST" class="flex items-end gap-3">
    <div class="flex-1"><input type="text" name="vessel_name" required placeholder="Vessel Name" class="input input-sm w-full"></div>
    <div><input type="date" name="scheduled_date" required class="input input-sm"></div>
    <div><input type="date" name="end_date" class="input input-sm"></div>
    <div><input type="text" name="quarter" placeholder="Q1 2025" class="input input-sm w-24"></div>
    <div class="flex-1"><input type="text" name="notes" placeholder="Notes" class="input input-sm w-full"></div>
    <button type="submit" class="btn btn-sm btn-success">Add</button>
  </form>
</div>

<% Object.entries(quarters).forEach(([q, items]) => { %>
<div class="card mb-4">
  <h3 class="text-sm font-semibold text-blue-400 mb-3"><%= q %></h3>
  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-2">
    <% items.forEach(item => { %>
      <div class="bg-slate-900 rounded-lg p-2 text-xs group relative">
        <div class="font-medium text-white truncate"><%= item.vessel_name %></div>
        <div class="text-slate-500"><%= new Date(item.scheduled_date).toLocaleDateString('en-GB', {day:'2-digit',month:'short'}) %></div>
        <button onclick="if(confirm('Delete?'))fetch('/drydock/<%= item.id %>',{method:'DELETE'}).then(()=>location.reload())" class="absolute top-1 right-1 text-red-400 opacity-0 group-hover:opacity-100 text-xs">✕</button>
      </div>
    <% }) %>
  </div>
</div>
<% }) %>
