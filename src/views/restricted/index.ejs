<% var pageTitle = 'Restricted Ships' %>
<div class="flex items-center justify-between mb-4">
  <h2 class="text-2xl font-bold text-white">Restricted Ships</h2>
  <div class="flex gap-1">
    <% categories.forEach(c => { %>
      <a href="/restricted?category=<%= c.key %>" class="btn btn-sm <%= selectedCat === c.key ? 'btn-primary' : 'bg-slate-700 text-white hover:bg-slate-600' %>"><%= c.label %></a>
    <% }) %>
  </div>
</div>
<div class="card mb-4">
  <form action="/restricted" method="POST" class="flex items-end gap-3">
    <input type="hidden" name="category" value="<%= selectedCat %>">
    <div class="flex-1"><input type="text" name="vessel_name" required placeholder="Vessel Name" class="input input-sm w-full"></div>
    <div class="flex-1"><input type="text" name="notes" placeholder="Notes" class="input input-sm w-full"></div>
    <button type="submit" class="btn btn-sm btn-success">Add</button>
  </form>
</div>
<div class="card p-0 overflow-hidden">
  <table class="data-table">
    <thead><tr><th>#</th><th>Vessel</th><th>Notes</th><th class="w-12"></th></tr></thead>
    <tbody>
      <% ships.forEach((s, i) => { %>
        <tr>
          <td class="text-slate-500"><%= i+1 %></td>
          <td class="font-medium text-white"><%= s.vessel_name %></td>
          <td class="text-slate-400"><%= s.notes || '' %></td>
          <td><button onclick="if(confirm('Delete?'))fetch('/restricted/<%= s.id %>',{method:'DELETE'}).then(()=>location.reload())" class="text-red-400 hover:text-red-300 text-xs">✕</button></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
